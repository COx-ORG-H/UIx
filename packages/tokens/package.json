{
  "name": "@tensor_1/tokens",
  "version": "2.4.0",
  "description": "UIx v2 design tokens — the --uix-* contract for house products (Tensor, POSx, SHOPx). One DTCG source -> CSS variables, Tailwind theme, and typed TS constants.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/COx-ORG-H/UIx.git",
    "directory": "packages/tokens"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build",
    "themes/*.css",
    "tokens"
  ],
  "exports": {
    "./css": "./build/css/tokens.css",
    "./styles": "./build/css/components.css",
    "./bundle": "./build/css/styles.css",
    "./tailwind": "./build/tailwind/theme.css",
    "./tailwind/preset": "./build/tailwind/preset.cjs",
    "./ts": {
      "types": "./build/ts/tokens.d.ts",
      "default": "./build/ts/tokens.js"
    },
    "./themes/tensor": "./themes/tensor.css",
    "./themes/posx": "./themes/posx.css",
    "./themes/shopx": "./themes/shopx.css",
    "./themes/mission-control": "./themes/mission-control.css"
  },
  "scripts": {
    "build:tokens": "node style-dictionary.config.mjs",
    "build:themes": "node scripts/build-themes.mjs",
    "build:styles": "node scripts/build-styles.mjs",
    "build": "npm run build:tokens && npm run build:themes && npm run build:styles",
    "test:parity": "node scripts/check-parity.mjs",
    "test:contract": "node scripts/check-contract.mjs",
    "prepublishOnly": "npm run build && npm run test:parity && npm run test:contract"
  },
  "devDependencies": {
    "postcss": "^8.4.0",
    "postcss-import": "^16.1.1",
    "style-dictionary": "^4.0.0"
  }
}
