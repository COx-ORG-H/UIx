{
  "bg-app":    { "$type": "color", "$value": "#0A0A0A" },
  "bg-subtle": { "$type": "color", "$value": "#171717" },
  "bg-hover":  { "$type": "color", "$value": "#1F1F1F" },
  "bg-active": { "$type": "color", "$value": "#262626" },
  "surface":   { "$type": "color", "$value": "#111111" },
  "surface-2": { "$type": "color", "$value": "#171717" },
  "surface-3": { "$type": "color", "$value": "#262626" },
  "border":        { "$type": "color", "$value": "rgba(255,255,255,.08)" },
  "border-strong": { "$type": "color", "$value": "rgba(255,255,255,.14)" },

  "text":        { "$type": "color", "$value": "#FAFAFA" },
  "text-hushed": { "$type": "color", "$value": "rgba(250,250,250,.64)" },
  "text-muted":  { "$type": "color", "$value": "#A1A1A1" },

  "accent":       { "$type": "color", "$value": "var(--uix-brand,#2563EB)" },
  "accent-hover": { "$type": "color", "$value": "color-mix(in srgb, var(--uix-accent) 82%, #FFFFFF)", "$description": "On dark, primary-button hover LIGHTENS the accent (the light-theme value darkens). Tracks the live brand override." },
  "link":         { "$type": "color", "$value": "color-mix(in srgb, var(--uix-brand,#5B8DEF) 70%, #FFFFFF)", "$description": "Brightened on dark so links read clearly as links and stay distinct from the solid accent button background." },
  "ring":         { "$type": "color", "$value": "var(--uix-brand,#3080FF)" },
  "brand-muted": { "$type": "color", "$value": "color-mix(in srgb, var(--uix-accent) 16%, transparent)" },

  "success":    { "$type": "color", "$value": "#00D294" },
  "success-fg": { "$type": "color", "$value": "#002C22" },
  "success-bg": { "$type": "color", "$value": "rgba(0,210,148,.15)" },
  "warning":      { "$type": "color", "$value": "#FCBB00" },
  "warning-fg":   { "$type": "color", "$value": "#1A1A1A" },
  "warning-bg":   { "$type": "color", "$value": "rgba(249,156,0,.16)" },
  "warning-text": { "$type": "color", "$value": "var(--uix-warning,#FCBB00)", "$description": "On dark the faint bg is dark enough that the bright warning hue reads as text — track --uix-warning live (fallback to the dark warning value)." },
  "info":       { "$type": "color", "$value": "#2563EB" },
  "info-fg":    { "$type": "color", "$value": "#FFFFFF" },
  "info-bg":    { "$type": "color", "$value": "rgba(48,128,255,.16)" },
  "danger":     { "$type": "color", "$value": "#DC2626" },
  "danger-fg":  { "$type": "color", "$value": "#FFFFFF" },
  "danger-bg":  { "$type": "color", "$value": "rgba(220,38,38,.20)" },

  "success-solid": { "$type": "color", "$value": "#34D399" },
  "warning-solid": { "$type": "color", "$value": "#FBBF24" },
  "info-solid":    { "$type": "color", "$value": "#3B82F6" },
  "danger-solid":  { "$type": "color", "$value": "#F87171" },

  "chart-1": { "$type": "color", "$value": "#3080FF" },
  "chart-2": { "$type": "color", "$value": "#00C2B0" },
  "chart-3": { "$type": "color", "$value": "#00D294" },
  "chart-4": { "$type": "color", "$value": "#FCBB00" },
  "chart-5": { "$type": "color", "$value": "#FF8B1A" },
  "chart-6": { "$type": "color", "$value": "#FF6568" },
  "chart-7": { "$type": "color", "$value": "#A685FF" },
  "chart-8": { "$type": "color", "$value": "#FF667F" },
  "chart-neutral": { "$type": "color", "$value": "#A1A1A1" },

  "row":           { "$type": "color", "$value": "#111111" },
  "row-alt":       { "$type": "color", "$value": "#161616" },
  "row-pinned-bg": { "$type": "color", "$value": "rgba(48,128,255,.08)" },

  "scrollbar-thumb":       { "$type": "color", "$value": "rgba(255,255,255,.18)" },
  "scrollbar-thumb-hover": { "$type": "color", "$value": "rgba(255,255,255,.30)" }
}
