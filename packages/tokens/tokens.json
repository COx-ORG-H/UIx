{
  "version": "1.0.0",
  "prefix": "uix",
  "_provenance": "Values: ITSMx/Docs/design-system.md (Ramp-calibrated) §1 color, §2 type, §4 radius/elevation, §5 motion, §8 dark. Derived additions are marked with _derived.",
  "tokens": {
    "bg-app":     { "type": "color", "light": "#FFFFFF", "dark": "#0E0D0C" },
    "bg-subtle":  { "type": "color", "light": "#F4F2F0", "dark": "#1A1817" },
    "bg-hover":   { "type": "color", "light": "#ECEAE6", "dark": "#252220" },
    "bg-active":  { "type": "color", "light": "#E7E4DF", "dark": "#322E2B" },
    "surface":    { "type": "color", "light": "#FFFFFF", "dark": "#1A1817" },
    "surface-2":  { "type": "color", "light": "#FFFFFF", "dark": "#252220" },
    "surface-3":  { "type": "color", "light": "#FFFFFF", "dark": "#322E2B" },

    "border":        { "type": "color", "light": "#D2CECB", "dark": "rgba(255, 255, 255, 0.08)" },
    "border-strong": { "type": "color", "light": "#C4BFBB", "dark": "rgba(255, 255, 255, 0.14)" },

    "text":               { "type": "color", "light": "#0C0A08", "dark": "#E3E0DB" },
    "text-hushed":        { "type": "color", "light": "rgba(12, 10, 8, 0.60)", "dark": "rgba(227, 224, 219, 0.60)" },
    "text-muted":         { "type": "color", "light": "#6E6A68", "dark": "rgba(227, 224, 219, 0.40)" },
    "text-reverse":       { "type": "color", "light": "#FFFFFF" },
    "text-hushed-reverse":{ "type": "color", "light": "rgba(255, 255, 255, 0.60)" },

    "accent":       { "type": "color", "light": "var(--uix-brand, #E4F222)" },
    "accent-dark":  { "type": "color", "light": "#CBD91F" },
    "accent-light": { "type": "color", "light": "#F5FF78" },
    "accent-fg":    { "type": "color", "light": "var(--uix-brand-fg, #0C0A08)" },
    "link":         { "type": "color", "light": "var(--uix-brand, #5683D2)", "dark": "var(--uix-brand, #82A4E2)" },
    "ring":         { "type": "color", "light": "var(--uix-brand, #5683D2)", "dark": "var(--uix-brand, #82A4E2)" },

    "brand":       { "type": "color", "slot": true, "_note": "Brand override slot — intentionally UNSET; accent/accent-fg/link/ring fall back to house values when no brand is declared. WRITE-ONLY: components must never read var(--uix-brand) (linter-enforced)." },
    "brand-fg":    { "type": "color", "slot": true, "_note": "Text on brand-filled surfaces; pairs with brand. Write-only slot." },
    "brand-muted": { "type": "color", "light": "color-mix(in srgb, var(--uix-accent) 12%, transparent)", "dark": "color-mix(in srgb, var(--uix-accent) 16%, transparent)", "_derived": "brand wash (selection/soft emphasis); chains brand->accent->this" },

    "success":    { "type": "color", "light": "#17332D", "dark": "#5EC08A" },
    "success-fg": { "type": "color", "light": "#FFFFFF", "dark": "#0C0A08" },
    "success-bg": { "type": "color", "light": "#E7F0EC", "dark": "rgba(94, 192, 138, 0.14)" },
    "warning":    { "type": "color", "light": "#E96516", "dark": "#F08A4A" },
    "warning-fg": { "type": "color", "light": "#FFFFFF", "dark": "#0C0A08", "_derived": "text on warning-filled surfaces; mirrors success-fg" },
    "warning-bg": { "type": "color", "light": "#FBE9DD", "dark": "rgba(240, 138, 74, 0.16)" },
    "info":       { "type": "color", "light": "#5683D2", "dark": "#82A4E2" },
    "info-fg":    { "type": "color", "light": "#FFFFFF", "dark": "#0C0A08", "_derived": "text on info-filled surfaces; mirrors success-fg" },
    "info-bg":    { "type": "color", "light": "#E4EBF6", "dark": "rgba(86, 131, 210, 0.16)" },
    "danger":     { "type": "color", "light": "#C53030", "dark": "#F26D6D", "_derived": "no destructive red in the Ramp spec; warm red, AA on both bases" },
    "danger-fg":  { "type": "color", "light": "#FFFFFF", "dark": "#0C0A08", "_derived": "text on danger-filled controls; mirrors success-fg (dark danger is light, fg flips near-black)" },
    "danger-bg":  { "type": "color", "light": "#FBE4E4", "dark": "rgba(242, 109, 109, 0.16)", "_derived": "see danger" },

    "font-sans": { "type": "font", "light": "\"Geist\", system-ui, sans-serif", "_note": "spec face is TWK Lausanne (licensed); Geist is the free default — license holders override" },
    "font-mono": { "type": "font", "light": "\"Geist Mono\", ui-monospace, monospace" },

    "text-display":    { "type": "size", "light": "40px" },
    "leading-display": { "type": "number", "light": "1.05" },
    "text-h2":         { "type": "size", "light": "24px" },
    "leading-h2":      { "type": "number", "light": "1.15" },
    "text-h3":         { "type": "size", "light": "15px" },
    "leading-h3":      { "type": "number", "light": "1.3" },
    "text-eyebrow":    { "type": "size", "light": "11px" },
    "leading-eyebrow": { "type": "number", "light": "1.2" },
    "text-body":       { "type": "size", "light": "14px" },
    "leading-body":    { "type": "number", "light": "1.5" },
    "text-meta":       { "type": "size", "light": "12.5px" },
    "leading-meta":    { "type": "number", "light": "1.4" },
    "text-data-hero":  { "type": "size", "light": "34px" },
    "leading-data-hero": { "type": "number", "light": "1.1" },
    "tracking-tight":  { "type": "size", "light": "-0.02em" },
    "tracking-eyebrow":{ "type": "size", "light": "0.06em" },

    "radius-sm":   { "type": "size", "light": "6px" },
    "radius-md":   { "type": "size", "light": "8px" },
    "radius-pill": { "type": "size", "light": "999px" },

    "shadow-sm":      { "type": "shadow", "light": "0 1px 2px rgba(12, 10, 8, 0.06)" },
    "shadow-popover": { "type": "shadow", "light": "0 8px 24px rgba(12, 10, 8, 0.08), 0 1px 2px rgba(12, 10, 8, 0.04)" },
    "shadow-overlay": { "type": "shadow", "light": "0 16px 48px rgba(12, 10, 8, 0.12)" },
    "highlight-top":  { "type": "shadow", "light": "inset 0 1px 0 rgba(255, 255, 255, 0)", "dark": "inset 0 1px 0 rgba(255, 255, 255, 0.04)" },

    "ease-out-strong": { "type": "easing", "light": "cubic-bezier(0.2, 0, 0, 1)" },
    "ease-out":        { "type": "easing", "light": "cubic-bezier(0.23, 1, 0.32, 1)" },
    "dur-fast":        { "type": "duration", "light": "120ms" },
    "dur":             { "type": "duration", "light": "160ms" },

    "row-h":     { "type": "size", "light": "56px" },
    "control-h": { "type": "size", "light": "36px" },
    "sidebar-w": { "type": "size", "light": "248px" }
  },
  "bridge": {
    "--background": "var(--uix-bg-app)",
    "--foreground": "var(--uix-text)",
    "--card": "var(--uix-surface)",
    "--card-foreground": "var(--uix-text)",
    "--popover": "var(--uix-surface-2)",
    "--popover-foreground": "var(--uix-text)",
    "--primary": "var(--uix-accent)",
    "--primary-foreground": "var(--uix-accent-fg)",
    "--secondary": "var(--uix-bg-subtle)",
    "--secondary-foreground": "var(--uix-text)",
    "--muted": "var(--uix-bg-subtle)",
    "--muted-foreground": "var(--uix-text-muted)",
    "--accent": "var(--uix-bg-hover)",
    "--accent-foreground": "var(--uix-text)",
    "--destructive": "var(--uix-danger)",
    "--destructive-foreground": "var(--uix-danger-fg)",
    "--border": "var(--uix-border)",
    "--input": "var(--uix-border)",
    "--ring": "var(--uix-ring)",
    "--radius": "var(--uix-radius-md)",
    "--success": "var(--uix-success)",
    "--warning": "var(--uix-warning)",
    "--info": "var(--uix-info)",
    "--danger": "var(--uix-danger)",
    "--sidebar": "var(--uix-bg-subtle)",
    "--sidebar-foreground": "var(--uix-text)",
    "--sidebar-primary": "var(--uix-accent)",
    "--sidebar-primary-foreground": "var(--uix-accent-fg)",
    "--sidebar-accent": "var(--uix-bg-hover)",
    "--sidebar-accent-foreground": "var(--uix-text)",
    "--sidebar-border": "var(--uix-border)",
    "--sidebar-ring": "var(--uix-ring)"
  },
  "tailwind": {
    "--color-uix-app": "var(--uix-bg-app)",
    "--color-uix-subtle": "var(--uix-bg-subtle)",
    "--color-uix-hover": "var(--uix-bg-hover)",
    "--color-uix-active": "var(--uix-bg-active)",
    "--color-uix-surface": "var(--uix-surface)",
    "--color-uix-surface-2": "var(--uix-surface-2)",
    "--color-uix-surface-3": "var(--uix-surface-3)",
    "--color-uix-line": "var(--uix-border)",
    "--color-uix-line-strong": "var(--uix-border-strong)",
    "--color-uix-text": "var(--uix-text)",
    "--color-uix-hushed": "var(--uix-text-hushed)",
    "--color-uix-muted": "var(--uix-text-muted)",
    "--color-uix-accent": "var(--uix-accent)",
    "--color-uix-accent-fg": "var(--uix-accent-fg)",
    "--color-uix-brand-muted": "var(--uix-brand-muted)",
    "--color-uix-link": "var(--uix-link)",
    "--color-uix-ring": "var(--uix-ring)",
    "--color-uix-success": "var(--uix-success)",
    "--color-uix-success-fg": "var(--uix-success-fg)",
    "--color-uix-success-bg": "var(--uix-success-bg)",
    "--color-uix-warning": "var(--uix-warning)",
    "--color-uix-warning-fg": "var(--uix-warning-fg)",
    "--color-uix-warning-bg": "var(--uix-warning-bg)",
    "--color-uix-info": "var(--uix-info)",
    "--color-uix-info-fg": "var(--uix-info-fg)",
    "--color-uix-info-bg": "var(--uix-info-bg)",
    "--color-uix-danger": "var(--uix-danger)",
    "--color-uix-danger-fg": "var(--uix-danger-fg)",
    "--color-uix-danger-bg": "var(--uix-danger-bg)",
    "--font-sans": "var(--uix-font-sans)",
    "--font-mono": "var(--uix-font-mono)",
    "--ease-out-strong": "var(--uix-ease-out-strong)",
    "--ease-out": "var(--uix-ease-out)",
    "--shadow-uix-sm": "var(--uix-shadow-sm)",
    "--shadow-uix-popover": "var(--uix-shadow-popover)",
    "--shadow-uix-overlay": "var(--uix-shadow-overlay)"
  }
}
