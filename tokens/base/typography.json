{
  "font-sans":    { "$type": "fontFamily", "$value": "\"Inter\",system-ui,sans-serif" },
  "font-heading": { "$type": "fontFamily", "$value": "\"IBM Plex Sans\",\"Inter\",system-ui,sans-serif" },
  "font-mono":    { "$type": "fontFamily", "$value": "\"IBM Plex Mono\",ui-monospace,monospace" },

  "text-display":   { "$type": "dimension", "$value": "40px" },
  "leading-display":{ "$type": "number",    "$value": "1.05" },
  "text-data-hero": { "$type": "dimension", "$value": "34px" },
  "leading-data-hero": { "$type": "number", "$value": "1.1" },
  "text-h2":   { "$type": "dimension", "$value": "24px" },
  "leading-h2":{ "$type": "number",    "$value": "1.15" },
  "text-h3":   { "$type": "dimension", "$value": "15px" },
  "leading-h3":{ "$type": "number",    "$value": "1.3" },
  "text-body":   { "$type": "dimension", "$value": "14px" },
  "leading-body":{ "$type": "number",    "$value": "1.5" },
  "text-meta":   { "$type": "dimension", "$value": "12.5px" },
  "leading-meta":{ "$type": "number",    "$value": "1.4" },
  "text-eyebrow":   { "$type": "dimension", "$value": "11px" },
  "leading-eyebrow":{ "$type": "number",    "$value": "1.2" },

  "tracking-tight":   { "$type": "dimension", "$value": "-0.02em" },
  "tracking-eyebrow": { "$type": "dimension", "$value": "0.06em" }
}
