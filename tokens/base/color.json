{
  "bg-app":    { "$type": "color", "$value": "#FAFAFA" },
  "bg-subtle": { "$type": "color", "$value": "#F5F5F5" },
  "bg-hover":  { "$type": "color", "$value": "#EFEFEF" },
  "bg-active": { "$type": "color", "$value": "#E5E5E5" },
  "surface":   { "$type": "color", "$value": "#FFFFFF" },
  "surface-2": { "$type": "color", "$value": "#FFFFFF" },
  "surface-3": { "$type": "color", "$value": "#FAFAFA" },
  "border":        { "$type": "color", "$value": "#E5E5E5" },
  "border-strong": { "$type": "color", "$value": "#D4D4D4" },

  "text":                { "$type": "color", "$value": "#0A0A0A" },
  "text-hushed":         { "$type": "color", "$value": "rgba(10,10,10,.62)" },
  "text-muted":          { "$type": "color", "$value": "#737373" },
  "text-reverse":        { "$type": "color", "$value": "#FFFFFF" },
  "text-hushed-reverse": { "$type": "color", "$value": "rgba(255,255,255,.62)" },

  "accent":       { "$type": "color", "$value": "var(--uix-brand,#1447E6)", "$description": "Runtime: chains through the write-only --uix-brand slot. Must stay var() to keep live brand override." },
  "accent-dark":  { "$type": "color", "$value": "#0E3AC0" },
  "accent-light": { "$type": "color", "$value": "#4D77F0" },
  "accent-hover": { "$type": "color", "$value": "color-mix(in srgb, var(--uix-accent) 88%, #000000)", "$description": "Primary-button hover. Theme-aware: derived from the live accent so it tracks the brand override (light darkens, dark lightens — see tokens/dark)." },
  "accent-fg":    { "$type": "color", "$value": "var(--uix-brand-fg,#FFFFFF)", "$description": "Runtime: chains through --uix-brand-fg." },
  "link":         { "$type": "color", "$value": "var(--uix-brand,#1447E6)", "$description": "Runtime: chains through --uix-brand." },
  "ring":         { "$type": "color", "$value": "var(--uix-brand,#1447E6)", "$description": "Runtime: chains through --uix-brand." },
  "brand-muted":  { "$type": "color", "$value": "color-mix(in srgb, var(--uix-accent) 12%, transparent)", "$description": "Runtime: color-mix of the live accent." },

  "success":    { "$type": "color", "$value": "#047857" },
  "success-fg": { "$type": "color", "$value": "#FFFFFF" },
  "success-bg": { "$type": "color", "$value": "#D0FAE5" },
  "warning":    { "$type": "color", "$value": "#F99C00" },
  "warning-fg": { "$type": "color", "$value": "#1A1A1A" },
  "warning-bg": { "$type": "color", "$value": "#FEF3D6" },
  "info":       { "$type": "color", "$value": "#1447E6" },
  "info-fg":    { "$type": "color", "$value": "#FFFFFF" },
  "info-bg":    { "$type": "color", "$value": "#E3EBFF" },
  "danger":     { "$type": "color", "$value": "#E40014" },
  "danger-fg":  { "$type": "color", "$value": "#FFFFFF" },
  "danger-bg":  { "$type": "color", "$value": "#FFE4E6" },

  "success-solid": { "$type": "color", "$value": "#10B981", "$description": "SOLID status role — the vivid fill/dot/pulse color, distinct from the legible TEXT role (--uix-success). Products override per brand." },
  "warning-solid": { "$type": "color", "$value": "#F59E0B", "$description": "SOLID status role (see success-solid)." },
  "info-solid":    { "$type": "color", "$value": "#2563EB", "$description": "SOLID status role (see success-solid)." },
  "danger-solid":  { "$type": "color", "$value": "#EF4444", "$description": "SOLID status role (see success-solid)." },

  "chart-1": { "$type": "color", "$value": "#2563EB" },
  "chart-2": { "$type": "color", "$value": "#0891B2" },
  "chart-3": { "$type": "color", "$value": "#16A34A" },
  "chart-4": { "$type": "color", "$value": "#F59E0B" },
  "chart-5": { "$type": "color", "$value": "#EA580C" },
  "chart-6": { "$type": "color", "$value": "#E11D48" },
  "chart-7": { "$type": "color", "$value": "#7C3AED" },
  "chart-8": { "$type": "color", "$value": "#DB2777" },
  "chart-neutral": { "$type": "color", "$value": "#64748B" },

  "row":           { "$type": "color", "$value": "#FFFFFF" },
  "row-alt":       { "$type": "color", "$value": "#FAFAFA" },
  "row-pinned-bg": { "$type": "color", "$value": "#F4F7FF" },

  "scrollbar-thumb":       { "$type": "color", "$value": "rgba(10,10,10,.20)" },
  "scrollbar-thumb-hover": { "$type": "color", "$value": "rgba(10,10,10,.34)" },
  "scrollbar-track":       { "$type": "color", "$value": "transparent" }
}
