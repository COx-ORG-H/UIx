{
  "name": "@uix/tokens",
  "version": "2.0.0",
  "description": "UIx v2 design tokens — the --uix-* contract for house products (ITSMx, POSx, SHOPx). One DTCG source -> CSS variables, Tailwind theme, and typed TS constants.",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "files": [
    "build",
    "themes/*.css",
    "tokens"
  ],
  "exports": {
    "./css": "./build/css/tokens.css",
    "./tailwind": "./build/tailwind/theme.css",
    "./tailwind/preset": "./build/tailwind/preset.cjs",
    "./ts": {
      "types": "./build/ts/tokens.d.ts",
      "default": "./build/ts/tokens.js"
    },
    "./themes/itsmx": "./themes/itsmx.css",
    "./themes/posx": "./themes/posx.css",
    "./themes/shopx": "./themes/shopx.css"
  },
  "scripts": {
    "build:tokens": "node style-dictionary.config.mjs",
    "build:themes": "node scripts/build-themes.mjs",
    "build": "npm run build:tokens && npm run build:themes",
    "test:parity": "node scripts/check-parity.mjs",
    "prepublishOnly": "npm run build && npm run test:parity"
  },
  "devDependencies": {
    "postcss": "^8.4.0",
    "style-dictionary": "^4.0.0"
  }
}
